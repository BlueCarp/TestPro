{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pomodoro Timer",
  "version": "0.1.0",
  "identifier": "com.testpro.pomodoro-timer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pomodoro Timer",
        "width": 400,
        "height": 500,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "notification": {
      "all": true
    },
    "store": {},
    "shell": {
      "open": true
    }
  }
}
